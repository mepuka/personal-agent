# Personal Agent — Environment Variables
# Copy to .env and fill in values. Never commit .env.

# ── API Keys (set per provider in agent.yaml) ────────────────────────────────

# Anthropic (default provider)
PA_ANTHROPIC_API_KEY=

# OpenAI
# PA_OPENAI_API_KEY=

# OpenRouter
# PA_OPENROUTER_API_KEY=

# Google Gemini
# PA_GOOGLE_API_KEY=

# ── Server ───────────────────────────────────────────────────────────────────

# Config file path (default: agent.yaml relative to cwd)
# PA_CONFIG_PATH=agent.yaml

# SQLite database path (default: ./personal-agent.sqlite)
# PERSONAL_AGENT_DB_PATH=./personal-agent.sqlite

# ── CLI ──────────────────────────────────────────────────────────────────────

# Server URL for CLI to connect to (default: http://localhost:3000)
# PA_SERVER_URL=http://localhost:3000
